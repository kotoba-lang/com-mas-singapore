// Mas_singapore clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace mas_singapore {

    entity Account {
        id: string @unique
        holderId: string
        iban: string
        currency: string
        balance: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Consent {
        id: string @unique
        accountId: string
        scope: string
        status: string
        expiresAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Transaction {
        id: string @unique
        accountId: string
        amount: float
        currency: string
        bookedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity PaymentInitiation {
        id: string @unique
        debtorAccount: string
        creditorAccount: string
        amount: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Institution {
        id: string @unique
        name: string
        bic: string
        country: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Filing {
        id: string @unique
        institutionId: string
        regime: string
        period: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
